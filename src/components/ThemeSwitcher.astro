---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  class="theme-toggle inline-flex items-center justify-center px-2.5 py-1.5 border border-fg-lighter/25 text-fg-lighter hover:border-special hover:text-special transition-all cursor-pointer"
  aria-label="Toggle dark / light theme"
  title="toggle theme"
>
  <Icon name="fa7-solid:moon" class="icon-moon w-4 h-4" />
  <Icon name="fa7-solid:sun" class="icon-sun w-4 h-4" />
</button>

<style>
  .theme-toggle .icon-sun {
    display: none;
  }
  :global([data-theme="light"]) .theme-toggle .icon-moon {
    display: none;
  }
  :global([data-theme="light"]) .theme-toggle .icon-sun {
    display: inline-block;
  }
</style>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const toggle = document.getElementById("theme-toggle");
    if (!toggle || toggle.dataset.bound) return;
    toggle.dataset.bound = "true";
    toggle.addEventListener("click", () =>
      setTheme(getTheme() === "dark" ? "light" : "dark"),
    );
  });
</script>
