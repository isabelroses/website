---
interface Props {
  title: string;
  href?: string;
  linkLabel?: string;
}

const { title, href, linkLabel = "view all →" } = Astro.props;
---

<div class="flex flex-row items-center gap-4">
  <h2 class="text-base shrink-0 lowercase font-bold tracking-[0.12em] text-special">
    {title}
  </h2>
  <span class="h-px flex-1 bg-card"></span>
  {
    href && (
      <a
        href={href}
        class="shrink-0 text-fg-lighter hover-special text-sm"
      >
        {linkLabel}
      </a>
    )
  }
</div>
