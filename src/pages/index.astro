---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import Base from "@layouts/Base.astro";
import PostCard from "@components/PostCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import NavCard from "@components/NavCard.astro";
import SectionHeader from "@components/SectionHeader.astro";
import SocialLinks from "@components/SocialLinks.astro";
import Spacer from "@components/Spacer.astro";

const posts = (
  await getCollection("blog", ({ data }) => {
    return !data.draft && !data.archived;
  })
).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

import { SITE_TITLES, SITE_DESCRIPTIONS, PROJECTS } from "@lib/consts";
---

<Base
  title={SITE_TITLES.index}
  description={SITE_DESCRIPTIONS.index}
  image="/index.png"
>
  <div class="w-full max-w-2xl flex flex-col gap-10 justify-between h-full">
    <section class="flex flex-col gap-6">
      <div class="flex flex-col items-center text-center gap-3">
        <Image
          src="/me.webp"
          alt="my avatar"
          width={88}
          height={88}
          class="rounded-full ring-1 ring-special/40 ring-offset-4 ring-offset-bg"
        />
        <h1
          class="text-4xl font-semibold smallcaps tracking-[0.18em]"
        >
          isabel
        </h1>
        <p class="text-fg-lighter">{SITE_DESCRIPTIONS.index}</p>
      </div>

      <Spacer />

      <p class="text-fg-lighter leading-relaxed text-center text-balance">
        i am a
        <a
          href="https://github.com/NixOS/org/blob/main/doc/nixpkgs-committers.md"
          target="_blank"
          class="text-special underline">nixpkgs commiter (i can merge prs)</a
        >, and for a little fun i also
        <a
          href="https://catppuccin.com/community/"
          class="text-special underline">moderate for catppuccin</a
        >. i write a lot of nix so your going to see a lot of my thoughts on
        that on this site.
      </p>

      <!-- <a -->
      <!--   href="/isabel_roses_cv.pdf" -->
      <!--   class="flex items-center gap-3 w-full px-4 py-3 rounded-lg border border-special/40 bg-special/10 text-sm text-special hover:bg-special/15 transition-all" -->
      <!-- > -->
      <!--   <Icon -->
      <!--     name="fa7-solid:circle-info" -->
      <!--     class="w-4 h-4 shrink-0 text-special" -->
      <!--   /> -->
      <!--   <p> -->
      <!--     i'm currently looking for work. -->
      <!--     <span class="underline">click view my cv</span> -->
      <!--   </p> -->
      <!-- </a> -->

      <SocialLinks />
    </section>

    <Spacer />

    <section class="flex flex-col gap-4">
      <h2 class="text-xl smallcaps tracking-[0.12em]">explore</h2>
      <nav class="grid grid-cols-2 gap-3">
        <NavCard href="/blog" label="blog" icon="fa7-solid:pen-nib" />
        <NavCard href="/projects" label="projects" icon="fa7-solid:code" />
        <NavCard href="/friends" label="friends" icon="fa7-solid:user-group" />
        <NavCard href="/donate" label="donate" icon="fa7-solid:heart" />
      </nav>
    </section>

    <section class="flex flex-col gap-4">
      <SectionHeader title="projects" href="/projects" />
      <ul class="flex flex-col gap-3">
        {
          PROJECTS.slice(0, 3).map((project) => (
            <li>
              <ProjectCard
                href={project.href || project.repo || "#"}
                name={project.name}
                icon={project.icon}
                stars={project.stars}
                compact
              />
            </li>
          ))
        }
      </ul>
    </section>

    <section class="flex flex-col gap-4">
      <SectionHeader title="recent posts" href="/blog" />
      <ul class="flex flex-col gap-3">
        {
          posts.slice(0, 5).map((post) => (
            <li>
              <PostCard
                href={`/blog/${post.id}`}
                title={post.data.title}
                date={post.data.date}
                compact
              />
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>
