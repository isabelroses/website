---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

import Base from "@layouts/Base.astro";
import NowPlaying from "@components/NowPlaying.astro";

const posts = (
  await getCollection("blog", ({ data }) => {
    return !data.draft && !data.archived;
  })
).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const latest = posts[0];
const latestDate = latest
  ? new Date(latest.data.date).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "short",
      year: "numeric",
    })
  : "";

import { SITE_TITLES, SITE_DESCRIPTIONS, LINKS } from "@lib/consts";
---

<Base
  title={SITE_TITLES.index}
  description={SITE_DESCRIPTIONS.index}
  image="/index.png"
>
  <div class="w-full flex flex-col gap-8">
    <section class="flex flex-col gap-4">
      <h1 class="sr-only">isabel — the nix witch</h1>
      <p class="text-fg-lighter leading-relaxed">
        i am a
        <a
          href="https://github.com/NixOS/org/blob/main/doc/nixpkgs-committers.md"
          target="_blank"
          class="text-special underline">nixpkgs committer (i can merge prs)</a
        >, and for a little fun i also
        <a
          href="https://catppuccin.com/community/"
          class="text-special underline">moderate for catppuccin</a
        >. i write a lot of nix so your going to see a lot of my thoughts on
        that on this site.
      </p>
    </section>

    <section class="flex flex-col gap-3">
      <h2 class="section-label">currently up to</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <NowPlaying />

        {
          latest && (
            <a
              href={`/blog/${latest.id}`}
              class="panel-link p-3 group flex items-center gap-3"
            >
              <div class="w-14 h-14 shrink-0 grid place-items-center rounded bg-card text-fg-lighter">
                <Icon name="fa7-solid:pen-nib" class="w-5 h-5" />
              </div>
              <div class="min-w-0">
                <div class="font-bold text-fg truncate group-hover-special">
                  {latest.data.title}
                </div>
                <div class="text-fg-lighter text-sm truncate">{latestDate}</div>
                <div class="section-label text-xs mt-1 normal-case">
                  ✎ latest post
                </div>
              </div>
            </a>
          )
        }
      </div>
    </section>

    <section class="flex flex-col gap-3">
      <h2 class="section-label">socials</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {
          LINKS.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="me noopener noreferrer"
              class="group flex items-center gap-3 panel-link p-3"
            >
              <Icon
                name={link.icon}
                class="w-5 h-5 shrink-0 text-fg-lighter group-hover-special"
              />
              <span class="flex flex-col min-w-0">
                <span class="text-fg font-bold lowercase group-hover-special">
                  {link.label}
                </span>
                <span class="text-fg-lighter text-sm truncate">
                  {link.handle}
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
